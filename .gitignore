# Large video files outside public/videos (GitHub rejects files over 100MB)
*.mp4
*.mov
*.webm
*.mkv

# Un-ignore deployable portfolio videos (must un-ignore directory, then files)
!public/videos/
!public/videos/*.mp4
!public/videos/*.mov
!public/videos/*.webm
!public/videos/*.mkv
!public/videos/**/*.mp4
!public/videos/**/*.mov
!public/videos/**/*.webm
!public/videos/**/*.mkv

